# Backend Environment Configuration
# Copy this file to .env and fill in the values

# ==================== SERVER ====================
NODE_ENV=development
PORT=4000
API_VERSION=v1

# ==================== DATABASE ====================
MONGODB_URI=mongodb://localhost:27017/broker-connect

# ==================== JWT ====================
JWT_SECRET=your_jwt_secret_key_min_32_chars_long
JWT_EXPIRE=7d

# ==================== CLOUDINARY ====================

CLOUDINARY_CLOUD_NAME=dbax7k2jn
CLOUDINARY_API_KEY=718457148579411
CLOUDINARY_API_SECRET=YzOX2t0AA2qvLzuQzrh_FJnCkbE
# API environment variable
CLOUDINARY_URL=cloudinary://718457148579411:YzOX2t0AA2qvLzuQzrh_FJnCkbE@dbax7k2jn

# ==================== CORS ====================
CORS_ORIGIN=http://localhost:3000,http://localhost:8081,https://yourdomain.com

# ==================== NGROK (DEVELOPMENT ONLY) ====================
NGROK_URL=https://your-ngrok-url.ngrok.io

# ==================== LOGGING ====================
LOG_LEVEL=debug
LOG_DIR=logs

# ==================== DEVELOPMENT ====================
DEBUG=broker-connect:*

# ==================== PRODUCTION ====================
# Uncomment these for production
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/broker-connect
# NODE_ENV=production
# LOG_LEVEL=info
